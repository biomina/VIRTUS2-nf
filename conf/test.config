/*
 * Test profile — uses tiny synthetic data to validate workflow graph.
 * Run with:  nextflow run main.nf -profile test -stub
 */
params {
    input              = "${projectDir}/test/data/samplesheet.csv"
    outdir             = "${projectDir}/test/results"
    genomeDir_human    = "${projectDir}/test/data/star_index_human"
    genomeDir_virus    = "${projectDir}/test/data/star_index_virus"
    kz_threshold       = 0.1
    th_cov             = 0.0
    th_rate            = 0.0
    figsize            = '4,2'
}

process {
    // Minimal resources for testing
    resourceLimits = [ cpus: 2, memory: '2.GB', time: '10.m' ]
}
