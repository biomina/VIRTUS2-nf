// Module-level publishDir and ext.args overrides

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: 'copy',
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // ── fastp ──────────────────────────────────────────────────────────────
    // 'legacy': fastp 0.20.0 — matches original CWL VIRTUS2
    // 'latest': fastp 1.0.1 — current best practice
    withName: 'FASTP' {
        container  = params.tool_versions == 'legacy' ?
            'quay.io/biocontainers/fastp:0.20.0--hdbcaa40_0' :
            'quay.io/biocontainers/fastp:1.0.1--heae3180_0'
        publishDir = [
            path: { "${params.outdir}/${meta.id}/fastp" },
            mode: 'copy',
            pattern: '*.{json,html,log}'
        ]
    }
    // PE-specific: legacy omits --detect_adapter_for_pe (matching CWL fastp 0.20.0 invocation)
    withName: 'VIRTUS_PE:FASTP' {
        ext.args   = params.tool_versions == 'legacy' ?
            '--trim_poly_x --length_required 40' :
            '--trim_poly_x --length_required 40 --detect_adapter_for_pe'
    }
    // SE-specific: no --detect_adapter_for_pe in either version
    withName: 'VIRTUS_SE:FASTP' {
        ext.args   = '--trim_poly_x --length_required 40'
    }

    // ── STAR: human alignment ───────────────────────────────────────────────
    // 'legacy': STAR 2.7.1a — matches original CWL VIRTUS2
    // 'latest': STAR 2.7.11b — current best practice
    withName: 'STAR_ALIGN_HUMAN' {
        // The nf-core STAR module now requires samtools+gawk in the same container (eval() outputs);
        // the default wave container community.wave.seqera.io/library/htslib_samtools_star_gawk
        // provides STAR 2.7.11b + samtools + gawk. Legacy mode now controls fastp only, not STAR.
        cpus       = 12
        memory     = 50.GB
        ext.args   = '--outSAMunmapped Within --outSAMtype BAM SortedByCoordinate --outSAMattributes NH HI AS NM MD --readFilesCommand zcat'
        ext.prefix = { "${params.outFileNamePrefix_human}" }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/star_human" },
            mode: 'copy',
            pattern: '*.{bam,out,tab}'
        ]
    }

    // ── STAR: virus alignment ───────────────────────────────────────────────
    withName: 'STAR_ALIGN_VIRUS' {
        cpus       = 12
        memory     = 50.GB
        ext.args   = '--outSAMtype BAM SortedByCoordinate --outSAMattributes NH HI AS NM MD --genomeSAindexNbases 12 --readFilesCommand zcat'
        ext.prefix = { 'virus' }
        publishDir = [
            path: { "${params.outdir}/${meta.id}/star_virus" },
            mode: 'copy',
            pattern: '*.{bam,out,tab}'
        ]
    }

    // ── STAR: genome generate (human) ───────────────────────────────────────
    // Human genome indexing needs ~32 GB; fixed cap well below available RAM
    withName: 'STAR_GENOMEGENERATE_HUMAN' {
        // --genomeSAindexNbases 14 avoids the auto-detect branch (samtools faidx + gawk) in the
        // new module when the container is overridden without those tools.
        cpus       = 8
        memory     = 40.GB
        ext.args   = '--genomeSAindexNbases 14'
        publishDir = [
            path: { "${params.outdir}/star_index/human" },
            mode: 'copy'
        ]
    }

    // ── STAR: genome generate (virus) ───────────────────────────────────────
    // Virus FASTA is ~7 MB — only needs a few GB
    withName: 'STAR_GENOMEGENERATE_VIRUS' {
        cpus       = 4
        memory     = { 4.GB * task.attempt }
        ext.args   = '--genomeSAindexNbases 12 --genomeChrBinNbits 10'
        publishDir = [
            path: { "${params.outdir}/star_index/virus" },
            mode: 'copy'
        ]
    }

    // ── samtools/view (unmapped extraction) ─────────────────────────────────
    withName: 'SAMTOOLS_VIEW' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/samtools" },
            mode: 'copy',
            pattern: '*.bam'
        ]
    }

    // ── samtools/fastq (intermediate — feeds virus STAR) ────────────────────
    withName: 'SAMTOOLS_FASTQ' {
        publishDir = [ enabled: false ]
    }

    // ── bedtools bamtofastq ──────────────────────────────────────────────────
    withName: 'BEDTOOLS_BAMTOFASTQ' {
        publishDir = [ enabled: false ]
    }

    // ── kz_filter ────────────────────────────────────────────────────────────
    withName: 'KZ_FILTER' {
        publishDir = [ enabled: false ]
    }

    // ── fastq_pair ────────────────────────────────────────────────────────────
    withName: 'FASTQ_PAIR' {
        publishDir = [ enabled: false ]
    }

    // ── bam_filter_polyx ─────────────────────────────────────────────────────
    withName: 'BAM_FILTER_POLYX' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/bam_filter_polyx" },
            mode: 'copy',
            pattern: '*.bam'
        ]
    }

    // ── samtools/index ────────────────────────────────────────────────────────
    withName: 'SAMTOOLS_INDEX' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}/bam_filter_polyx" },
            mode: 'copy',
            pattern: '*.bai'
        ]
    }

    // ── samtools/coverage ─────────────────────────────────────────────────────
    withName: 'SAMTOOLS_COVERAGE' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}" },
            mode: 'copy'
        ]
    }

    // ── mk_summary_virus_count ────────────────────────────────────────────────
    withName: 'MK_SUMMARY_VIRUS_COUNT' {
        publishDir = [
            path: { "${params.outdir}/${meta.id}" },
            mode: 'copy'
        ]
    }

    // ── wget / gunzip (FASTA download + decompress — intermediate) ───────────
    withName: 'WGET_HUMAN|WGET_VIRUS' {
        publishDir = [ enabled: false ]
    }

    withName: 'GUNZIP_HUMAN' {
        publishDir = [ enabled: false ]
    }

    // ── virtus_aggregate ──────────────────────────────────────────────────────
    withName: 'VIRTUS_AGGREGATE' {
        publishDir = [
            path: { "${params.outdir}/aggregate" },
            mode: 'copy'
        ]
    }
}
