manifest {
    name            = 'VIRTUS2-nf'
    description     = 'Viral Transcript Usage from RNA-Seq v2 — Nextflow port'
    version         = '2.0.0'
    nextflowVersion = '!>=23.04.0'
}

params {
    // Input / output
    input                   = null
    outdir                  = 'results'

    // Reference indices (pre-built); if absent, pipeline will build them
    genomeDir_human         = null
    genomeDir_virus         = null

    // Reference FASTAs for index building (used when genomeDir_* not supplied)
    fasta_human             = null
    fasta_virus             = null
    // Remote fallback URLs used when neither genomeDir nor fasta are supplied
    url_fasta_human         = 'https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_38/GRCh38.p13.genome.fa.gz'
    url_fasta_virus         = 'https://raw.githubusercontent.com/yyoshiaki/VIRTUS2/master/data/viruses.fasta'

    // BAM → FASTQ conversion tool
    // 'samtools' : samtools fastq (modern, no coord-sort duplication bug)
    // 'bedtools'  : bedtools bamtofastq 2.29.2 (exact match to original CWL)
    bam_to_fastq_tool       = 'samtools'

    // Tool version profile
    // 'legacy' : original CWL VIRTUS2 versions — fastp 0.20.0 (no --detect_adapter_for_pe) + STAR 2.7.1a
    // 'latest' : current best-practice versions — fastp 1.0.1 (with --detect_adapter_for_pe for PE) + STAR 2.7.11b
    tool_versions           = 'latest'

    // Analysis parameters
    kz_threshold            = 0.1
    outFileNamePrefix_human = 'human'
    filename_output         = 'VIRTUS.output.tsv'

    // Aggregation / visualisation
    th_cov                  = 10.0
    th_rate                 = 0.0001
    figsize                 = '8,3'
}

// Load base process config
includeConfig 'conf/base.config'

// Load module-level publishDir / ext.args
includeConfig 'conf/modules.config'

profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
        conda.enabled          = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        conda.enabled          = false
    }
    conda {
        conda.enabled          = true
        docker.enabled         = false
        singularity.enabled    = false
    }
    test {
        includeConfig 'conf/test.config'
    }
}

// Capture exit codes from upstream processes when piping
process.shell = ['/bin/bash', '-euo', 'pipefail']

// Export NXF_WORK to prevent staging issues
env {
    NXF_ANSI_LOG = false
}

def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline_${trace_timestamp}.html"
}
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report_${trace_timestamp}.html"
}
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace_${trace_timestamp}.txt"
}
